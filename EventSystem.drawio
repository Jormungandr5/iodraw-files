        <mxCell id="Iy3axCZ3-uKmuE2MSwp1-25" parent="Iy3axCZ3-uKmuE2MSwp1-24" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;ul data-v-md-line=&quot;42&quot; style=&quot;box-sizing: inherit; margin: 1em 0px; padding-left: 1.2em; line-height: 1.7; color: rgb(44, 62, 80); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Fira Sans&amp;quot;, &amp;quot;Droid Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 14px; text-align: start; background-color: rgb(247, 247, 248);&quot;&gt;&lt;li style=&quot;box-sizing: inherit;&quot;&gt;&lt;span style=&quot;box-sizing: inherit; font-weight: 600;&quot;&gt;event 是基于 delegate 的一种封装&lt;/span&gt;，用于实现“发布—订阅”模式（Pub-Sub）。&lt;/li&gt;&lt;li style=&quot;box-sizing: inherit;&quot;&gt;它通常用于对象之间通信，比如 UI 点击、玩家死亡等。&lt;/li&gt;&lt;li style=&quot;box-sizing: inherit;&quot;&gt;与普通委托不同，&lt;code style=&quot;box-sizing: inherit; font-family: source-code-pro, Menlo, Monaco, Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.85em; margin: 0px; padding: 0.25rem 0.5rem; color: rgb(71, 101, 130); background-color: rgba(27, 31, 35, 0.05); border-radius: 3px;&quot;&gt;event&lt;/code&gt;&amp;nbsp;限制外部只能&amp;nbsp;&lt;code style=&quot;box-sizing: inherit; font-family: source-code-pro, Menlo, Monaco, Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.85em; margin: 0px; padding: 0.25rem 0.5rem; color: rgb(71, 101, 130); background-color: rgba(27, 31, 35, 0.05); border-radius: 3px;&quot;&gt;+=&lt;/code&gt;&amp;nbsp;或&amp;nbsp;&lt;code style=&quot;box-sizing: inherit; font-family: source-code-pro, Menlo, Monaco, Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 0.85em; margin: 0px; padding: 0.25rem 0.5rem; color: rgb(71, 101, 130); background-color: rgba(27, 31, 35, 0.05); border-radius: 3px;&quot;&gt;-=&lt;/code&gt;&amp;nbsp;订阅/取消，而不能直接调用（invoke）。&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="120" width="366.25" x="1.88" y="60" as="geometry" />
        </mxCell>
        <mxCell id="Iy3axCZ3-uKmuE2MSwp1-26" parent="Iy3axCZ3-uKmuE2MSwp1-24" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=6" value="&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Event:&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;（&lt;/font&gt;&lt;/b&gt;&lt;span style=&quot;box-sizing: inherit; font-weight: 600; color: rgb(44, 62, 80); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Fira Sans&amp;quot;, &amp;quot;Droid Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 14px; font-style: normal; text-align: start; background-color: rgb(247, 247, 248);&quot;&gt;delegate 是一种类型&lt;/span&gt;&lt;span style=&quot;color: rgb(44, 62, 80); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Fira Sans&amp;quot;, &amp;quot;Droid Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif; font-size: 14px; font-style: normal; text-align: start; background-color: rgb(247, 247, 248);&quot;&gt;，可以理解为“函数指针”的安全版本&lt;/span&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;）&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
